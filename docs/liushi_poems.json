[
  {"no": 1, "poem": ["日出便見風雲散", "光明清淨照世間", "一向前途通大道", "萬事清吉保平安"]},
  {"no": 2, "poem": ["靈雞漸漸見分明", "凡事且看子丑寅", "雲開月出照天下", "郎君即便見太平"]},
  {"no": 3, "poem": ["十方佛法有靈通", "大難禍患不相同", "紅日當空常照耀", "還有貴人到家堂"]},
  {"no": 4, "poem": ["綠柳蒼蒼正當時", "任君此去作乾坤", "花果結實無殘謝", "福祿自有慶家門"]},
  {"no": 5, "poem": ["今行到此實難推", "歌歌暢飲自徘徊", "雞犬相聞消息近", "婚姻夙世結成雙"]},
  {"no": 6, "poem": ["東西南北不堪行", "前途此事正可當", "勸君把定莫煩惱", "家門自有保安康"]},
  {"no": 7, "poem": ["於今此景正當時", "看看欲吐百花魁", "若能遇得春色到", "一灑清吉脫塵埃"]},
  {"no": 8, "poem": ["長江風浪漸漸靜", "于今得進可安寧", "必有貴人相扶助", "凶事脫出見太平"]},
  {"no": 9, "poem": ["太公家業八十成", "月出光輝四海明", "命內自然逢大吉", "茅屋中間百事亨"]},
  {"no": 10, "poem": ["龍虎相交在門前", "此事必定兩相連", "黃金忽然變成鐵", "何用作福問神仙"]},
  {"no": 11, "poem": ["一重江水一重山", "誰知此去路又難", "任他改求終不過", "是非終久未得安"]},
  {"no": 12, "poem": ["功名事業本由天", "不須掛念意懸懸", "若問中間遲與速", "風雲際會在眼前"]},
  {"no": 13, "poem": ["勸君把定心莫虛", "天註衣祿自有餘", "和合重重常吉慶", "時來終遇得明珠"]},
  {"no": 14, "poem": ["命中正逢羅孛關", "用盡心機總未休", "作福問神難得過", "恰是行舟上高灘"]},
  {"no": 15, "poem": ["欲去長江水闊茫", "前途未遂運未通", "如今絲綸常在手", "只恐魚水不相逢"]},
  {"no": 16, "poem": ["欲去長江水闊茫", "行舟把定未遭風", "戶內用心再作福", "看看魚水得相逢"]},
  {"no": 17, "poem": ["一年作事急如飛", "君爾寬心莫遲疑", "貴人還在千里外", "音信月中漸漸知"]},
  {"no": 18, "poem": ["看君來問心中事", "積善之家慶有餘", "運亨財子雙雙至", "指日喜氣溢門閭"]},
  {"no": 19, "poem": ["風恬浪靜可行舟", "恰是中秋月一輪", "凡事不須多憂慮", "福祿自有慶家門"]},
  {"no": 20, "poem": ["財中漸漸見分明", "花開花謝結子成", "寬心且看月中桂", "郎君即便見太平"]},
  {"no": 21, "poem": ["月出光輝四海明", "前途祿位見太平", "浮雲掃退終無事", "可保禍患不臨身"]},
  {"no": 22, "poem": ["危險高山行過盡", "莫嫌此路有重重", "若見蘭桂漸漸發", "長蛇反轉變成龍"]},
  {"no": 23, "poem": ["客到前途多得利", "君爾何故兩相疑", "雖是中間防進退", "月出光輝得運時"]},
  {"no": 24, "poem": ["孤燈寂寂夜沉沉", "萬事清吉萬事成", "若逢陰中有善果", "燒得好香達神明"]},
  {"no": 25, "poem": ["只恐前途命有變", "勸君作急可宜先", "且守長江無大事", "命逢太白守身邊"]},
  {"no": 26, "poem": ["八十原來是太公", "看看晚景遇文王", "目下緊事休相問", "勸君且守待運通"]},
  {"no": 27, "poem": ["總是前途莫心勞", "求神問聖枉是多", "但看雞犬日過後", "不須作福事如何"]},
  {"no": 28, "poem": ["此事何須用心機", "前途變怪自然知", "看看此去得和合", "漸漸脫出見太平"]},
  {"no": 29, "poem": ["花開今已結成果", "富貴榮華終到老", "君子小人相會合", "萬事清吉莫煩惱"]},
  {"no": 30, "poem": ["須知進退總言虛", "看看發暗未必全", "珠玉深藏還未變", "心中但得枉徒然"]},
  {"no": 31, "poem": ["風雲致雨落洋洋", "天災時氣必有傷", "命內此事難和合", "更逢一足出外鄉"]},
  {"no": 32, "poem": ["不須作福不須求", "用盡心機總未休", "陽世不知陰世事", "官法如爐不自由"]},
  {"no": 33, "poem": ["選出牡丹第一枝", "勸君折取莫遲疑", "世間若問相知處", "萬事逢春正及時"]},
  {"no": 34, "poem": ["福如東海壽如山", "君爾何須嘆苦難", "命內自然逢大吉", "祈保分明自平安"]},
  {"no": 35, "poem": ["功名得意與君顯", "前途富貴喜安然", "若遇一輪明月照", "十五團圓光滿天"]},
  {"no": 36, "poem": ["病中若得苦心勞", "到底完全總未遭", "去後不須回頭問", "心中事務盡消磨"]},
  {"no": 37, "poem": ["雲開月出正分明", "不須進退問前程", "婚姻皆由天註定", "和合清吉萬事成"]},
  {"no": 38, "poem": ["舊恨重重未改為", "家中禍患不臨身", "須當謹防宜作福", "龍蛇交會得和合"]},
  {"no": 39, "poem": ["君爾寬心且自由", "門庭清吉家無憂", "財寶自然終吉利", "凡事無傷不用求"]},
  {"no": 40, "poem": ["運逢得意身顯變", "君爾身中皆有益", "一向前途無難事", "決意之中保清吉"]},
  {"no": 41, "poem": ["君爾何須問聖跡", "自己心中皆有益", "於今且看月中旬", "凶事脫出化成吉"]},
  {"no": 42, "poem": ["於今此景正當時", "看看欲吐百花魁", "若能遇得春色到", "一灑清吉脫塵埃"]},
  {"no": 43, "poem": ["禾稻看看結成完", "此事必定兩相全", "回到家中寬心坐", "妻兒鼓舞樂團圓"]},
  {"no": 44, "poem": ["君問中間此言因", "看看祿馬拱前程", "若得貴人多得利", "和合自有兩分明"]},
  {"no": 45, "poem": ["於今莫作此當時", "虎落平陽被犬欺", "世間凡事何難定", "千山萬水也遲疑"]},
  {"no": 46, "poem": ["名顯有意在中央", "不須祈禱心自安", "看看早晚日過後", "即時得意在其間"]},
  {"no": 47, "poem": ["陽世作事未和同", "雲遮月色正朦朧", "心中意欲前途去", "只恐命內運未通"]},
  {"no": 48, "poem": ["蛇身意欲變成龍", "只恐命內運未通", "久病且作寬心坐", "言語雖多不可從"]},
  {"no": 49, "poem": ["龍虎相隨在深山", "君爾何須背後看", "不知此去相愛愉", "他日與我卻無干"]},
  {"no": 50, "poem": ["富貴由命天註定", "心高必然誤君期", "不然且回依舊路", "雲開月出自分明"]},
  {"no": 51, "poem": ["枯木可惜未逢春", "如今反在暗中藏", "寬心且守風霜退", "還君依舊作乾坤"]},
  {"no": 52, "poem": ["意中若問神仙路", "勸爾且退望高樓", "寬心且守寬心坐", "必然遇得貴人扶"]},
  {"no": 53, "poem": ["言語雖多不可從", "風雲靜處未行龍", "暗中終得明消息", "君爾何須問重重"]},
  {"no": 54, "poem": ["有心作福莫遲疑", "求名清吉正當時", "此事必能成會合", "財寶自然喜相隨"]},
  {"no": 55, "poem": ["花開結子一半枯", "可惜今年汝虛度", "漸漸日落西山去", "勸君不用向前途"]},
  {"no": 56, "poem": ["前途功名未得意", "只恐命內有交加", "兩家必定防損失", "勸君且退莫咨嗟"]},
  {"no": 57, "poem": ["漸漸看此月中和", "過後須防未得高", "改變顏色前途去", "凡事必定見重勞"]},
  {"no": 58, "poem": ["平生富貴成祿位", "君家門戶定光輝", "此中必定無損失", "夫妻百歲喜相隨"]},
  {"no": 59, "poem": ["佛前發誓無異心", "且看前途得好音", "此物原來本是鐵", "也能變化得成金"]},
  {"no": 60, "poem": ["月出光輝本清吉", "浮雲總是蔽陰色", "戶內用心再作福", "當官分理便有益"]}
]
